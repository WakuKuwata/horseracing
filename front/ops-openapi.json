  "info": {
    "description": "On-demand netkeiba refresh — enqueue + job status (Feature 024). Write path, separate from the read-only 014 API.",
    "title": "horseracing ops (data-refresh) API",
    "version": "v1"
  },
  "openapi": "3.1.0",
  "paths": {
    "/ops/v1/batches/{trace_id}": {
      "get": {
        "operationId": "get_batch_ops_v1_batches__trace_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "trace_id",
            "required": true,
            "schema": {
              "title": "Trace Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Batch"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": "Not Found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Batch",
        "tags": [
          "jobs"
        ]
      }
    },
    "/ops/v1/days/{date}/refresh": {
      "post": {
        "description": "Accept a day refresh and return 202 immediately. The worker discovers the day's races from\nnetkeiba and fans out refresh_race children; poll the batch for progress. No netkeiba round-trip\nhere (never block), and any date is accepted — discovery (not the DB) decides the race set.",
        "operationId": "refresh_day_ops_v1_days__date__refresh_post",
        "parameters": [
          {
            "in": "path",
            "name": "date",
            "required": true,
            "schema": {
              "format": "date",
              "title": "Date",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "anyOf": [
                  {
                    "$ref": "#/components/schemas/RefreshRequest"
                  },
                  {
                    "type": "null"
                  }
                ],
                "title": "Body"
              }
            }
          }
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BatchAccepted"
                }
              }
            },
            "description": "Successful Response"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": "Not Found"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": "Unprocessable Entity"
          }
        },
        "summary": "Refresh Day",
        "tags": [
          "refresh"
        ]
      }
    },
