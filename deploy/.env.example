# 018 本番デプロイ — 環境変数テンプレート。`deploy/.env` にコピーして使う（実 .env はコミットしない）。

# --- postgres (compose 内 = local/staging。本番は外部マネージド DB を推奨) ---
POSTGRES_DB=horseracing
POSTGRES_USER=hr_owner
POSTGRES_PASSWORD=change-me-owner

# --- read-only serving role (API が使う。SELECT のみ) ---
APP_RO_USER=app_ro
APP_RO_PASSWORD=change-me-ro

# --- 接続文字列 ---
# migration / role 作成は owner。API serving は app_ro（read-only）。
DATABASE_URL_OWNER=postgresql+psycopg://hr_owner:change-me-owner@db:5432/horseracing
DATABASE_URL=postgresql+psycopg://app_ro:change-me-ro@db:5432/horseracing

# alembic migrations location inside the image (health head check + migrate)
ALEMBIC_SCRIPT_LOCATION=/app/db/migrations
